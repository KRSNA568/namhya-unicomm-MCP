APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

UNICOMMERCE_BASE_URL=https://namhyafood.unicommerce.co.in/services/soap/?version=1.9
UNICOMMERCE_WSDL_URL=https://namhyafood.unicommerce.co.in/services/soap/uniware19.wsdl
UNICOMMERCE_USERNAME=
UNICOMMERCE_PASSWORD=
UNICOMMERCE_TIMEOUT_SECONDS=60
UNICOMMERCE_MAX_RETRIES=3
UNICOMMERCE_RETRY_BACKOFF_SECONDS=2

# How many records per SOAP page request
PAGE_SIZE=50
# Max pages fetched per tool call (guards against very large result sets)
MAX_PAGES=10

LOW_STOCK_THRESHOLD=10
SHIPMENT_DELAY_THRESHOLD_HOURS=24
